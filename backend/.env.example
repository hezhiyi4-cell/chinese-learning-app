
# 中文学习App - 环境变量配置
# 复制此文件为 .env 并填入真实值

# 服务器配置
# 本地默认 8080；Render 会自动提供 PORT，代码已兼容
SERVER_PORT=8080

# JWT 密钥（生产环境请修改为强密码）
JWT_SECRET=your-secret-key-change-in-production-please

# OpenAI API Key（可选，用于 AI 功能）
# 获取方式：https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# SQLite 配置
# Render 免费版重启/休眠/重新部署后会丢失本地文件，仅适合演示
# 如果升级到可挂载磁盘的套餐，可改为 /var/data/chinese_learning.db
SQLITE_PATH=chinese_learning.db

# 上传目录
# 如果升级到可挂载磁盘的套餐，可改为 /var/data/uploads
UPLOAD_DIR=./uploads

# 数据库配置（当前 SQLite 方案下不使用，保留作后续迁移）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chinese_learning

# Redis 配置（暂时使用内存存储，暂不需要）
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# 前端回跳地址
# 线上请填写你的 Vercel 域名，不要带结尾斜杠
# 例如：https://chinese-learning-app-jade.vercel.app
FRONTEND_BASE_URL=

# PayPal Sandbox 配置
# 先在 PayPal Developer 创建 Sandbox Business App，再把下面两项填进来
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# 说明：
# 1. 当前代码已接通 PayPal Sandbox / mock 流程
# 2. Stripe / 连连国际目前是网关预留位，后续接入时再补充对应环境变量
